{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist/",
    "paths": {
      "@/*": ["./src/*"]
    },
    
    "target": "es2015",
    "module": "ESNext",
    "moduleResolution": "bundler",
    
    "jsx": "react-jsx",
    "allowJs": true,
    
    "noImplicitAny": true,
    "strictNullChecks": true,
    
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true
  },
  "include": ["src"]
}